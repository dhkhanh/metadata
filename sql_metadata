-- 1. Bảng định nghĩa Form nhập liệu
CREATE TABLE form_definition (
    id UUID PRIMARY KEY,
    form_code VARCHAR(100) UNIQUE NOT NULL,
    entity_id UUID NOT NULL, -- Liên kết với Entity (ví dụ: Đơn hàng, Nhân viên)
    name VARCHAR(255) NOT NULL, -- Tên form
    fields_config JSONB,        -- Cấu hình các trường: loại input, validation rules
    layout_config JSONB,        -- Cấu hình bố cục: chia cột, chia tab
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

-- 2. Bảng định nghĩa danh sách/View dữ liệu
CREATE TABLE view_definition (
    id UUID PRIMARY KEY,
    view_code VARCHAR(100) UNIQUE NOT NULL,
    entity_id UUID NOT NULL,
    name VARCHAR(255) NOT NULL,
    columns_config JSONB,       -- Danh sách cột hiển thị, độ rộng, thứ tự
    filter_config JSONB,        -- Điều kiện lọc mặc định (ví dụ: chỉ hiện đơn hàng chưa duyệt)
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

-- 3. Bảng định nghĩa Screen (Màn hình tổng thể)
CREATE TABLE screen_definition (
    id UUID PRIMARY KEY,
    screen_code VARCHAR(100) UNIQUE NOT NULL,
    name VARCHAR(255) NOT NULL, -- Tên màn hình (ví dụ: Quản lý kho)
    permission_code VARCHAR(100), -- Quyền truy cập màn hình
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP);

-- 4. Bảng liên kết giữa Seens và Form, View là bảng screen_component
CREATE TABLE screen_component
(
    id UUID PRIMARY KEY,
    screen_id UUID NOT NULL,
    component_type VARCHAR(50),
    component_id UUID NOT NULL,
    display_order INT,
    region VARCHAR(100)
);

